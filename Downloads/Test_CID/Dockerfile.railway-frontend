# Electra web app (Vite SPA) for Railway.
#
# Default matches Railway when Root Directory is EMPTY (repo root = Electra):
#   Dockerfile path: Downloads/Test_CID/Dockerfile.railway-frontend
#
# If Root Directory is "Downloads/Test_CID" instead, add a Docker build argument:
#   MONOREPO_PREFIX=.
#
# Variables: VITE_BACKEND_URL at build time. Backend CORS_ORIGIN must list the frontend URL.

ARG MONOREPO_PREFIX=Downloads/Test_CID

FROM node:20-bookworm-slim AS builder
ARG MONOREPO_PREFIX
WORKDIR /app

COPY ${MONOREPO_PREFIX}/package.json ${MONOREPO_PREFIX}/package-lock.json ./
COPY ${MONOREPO_PREFIX}/packages/frontend/package.json packages/frontend/
COPY ${MONOREPO_PREFIX}/packages/backend/package.json packages/backend/
COPY ${MONOREPO_PREFIX}/packages/desktop/package.json packages/desktop/

RUN npm ci

COPY ${MONOREPO_PREFIX}/App_Icon.jpg ./
COPY ${MONOREPO_PREFIX}/turbo.json ./
COPY ${MONOREPO_PREFIX}/packages/frontend ./packages/frontend
COPY ${MONOREPO_PREFIX}/packages/desktop/package.json ./packages/desktop/package.json

ARG VITE_BACKEND_URL=https://electra-backend.up.railway.app
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL

RUN npm run build --workspace=@cord/frontend

FROM node:20-bookworm-slim
WORKDIR /app
RUN npm install -g serve@14
COPY --from=builder /app/packages/frontend/dist ./dist
ENV NODE_ENV=production
CMD ["sh", "-c", "serve -s dist -l \"${PORT:-3000}\""]
