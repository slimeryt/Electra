{
  "name": "@cord/desktop",
  "version": "1.12.4",
  "description": "Electra desktop app",
  "author": "slimeryt",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.json\" \"wait-on tcp:5173 && electron .\"",
    "build": "cd ../frontend && npx vite build && cd ../desktop && node build-win.js",
    "typecheck": "node tsc-run.js --noEmit",
    "pack": "node build-win.js --dir"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "7zip-bin": "^5.2.0",
    "concurrently": "^8.2.0",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.electra.app",
    "productName": "Electra",
    "copyright": "Copyright © 2024 slimeryt",
    "icon": "assets/icon",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "publish": {
      "provider": "github",
      "owner": "slimeryt",
      "repo": "Electra",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "../frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "src/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.social-networking",
      "darkModeSupport": true
    },
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "signDlls": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "ElectraInstaller.exe",
      "include": "scripts/install-dir.nsh"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network"
    },
    "npmRebuild": false,
    "beforePack": "./scripts/beforePack.js",
    "forceCodeSigning": false
  }
}
