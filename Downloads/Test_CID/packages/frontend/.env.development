# Loaded automatically when you run `vite` / `npm run dev` (development mode).
# The web app still uses Vite’s proxy to localhost:3001 for /api — unchanged.
# Electron loads the UI from this dev server but is not proxied, so it needs an
# absolute API URL. Without this file, the desktop dev build defaulted to
# http://localhost:3001 and login failed unless the backend ran locally.
#
# Override locally: copy to .env.development.local (gitignored) and set e.g.
# VITE_BACKEND_URL=http://localhost:3001
VITE_BACKEND_URL=https://electra-backend.up.railway.app
