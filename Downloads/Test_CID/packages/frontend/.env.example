# Backend origin (no trailing slash). Required for production builds that do not use Vite’s proxy:
# - Electron desktop
# - Android / iOS (Capacitor) — without this, the app calls https://localhost and login fails.
#
# Dev in browser: can point here too, or leave default and use Vite proxy for /api.
# Android emulator hitting a backend on your PC: often http://10.0.2.2:3001
VITE_BACKEND_URL=http://localhost:3001
