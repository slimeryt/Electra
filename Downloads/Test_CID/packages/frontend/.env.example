# Backend origin (no trailing slash). Required when the UI is not served with Vite’s /api proxy:
# - Electron desktop (dev + prod)
# - Android / iOS (Capacitor)
#
# Development:
# - Browser at localhost:5173: usually omit this and use Vite proxy → localhost:3001.
# - Electron dev: use .env.development (see repo) or this file — otherwise the app
#   falls back to http://localhost:3001 and login fails if the API is only on Railway.
#
# Production: .env.production in the repo points at Railway; CI also sets the variable.
# Android emulator → PC: often http://10.0.2.2:3001
VITE_BACKEND_URL=http://localhost:3001
